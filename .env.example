# Скопируйте в .env перед docker compose build:
#   cp .env.example .env

# Только localhost — снаружи отдаёт nginx
BIND_ADDRESS=127.0.0.1
FRONTEND_PORT=3000

# URL API для сборки образа (поддомен api.*)
API_BASE_URL=https://api.aeonbiblio.chickenkiller.com

IMAGE_TAG=latest

