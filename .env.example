# Скопируйте в .env перед docker compose build:
#   cp .env.example .env

# Только localhost — снаружи отдаёт nginx на team16.st.ifbest.org
BIND_ADDRESS=127.0.0.1
FRONTEND_PORT=3000

# Относительный URL API (same-origin через nginx /api/)
API_BASE_URL=/api

IMAGE_TAG=latest

# --- Локальная разработка ---
# BIND_ADDRESS=0.0.0.0
# API_BASE_URL=http://localhost:8000
