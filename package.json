{
  "name": "frontend",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.14.0",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "generate-routes": "tsr generate",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "start": "node .output/server/index.mjs",
    "prepare": "husky",
    "lint": "eslint",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "unused": "knip",
    "dup": "jscpd src --config .jscpd.json",
    "size": "size-limit",
    "lighthouse:ci": "lhci autorun --config=.lighthouserc.json",
    "check": "pnpm lint && pnpm typecheck && pnpm format:check && pnpm test && pnpm unused && pnpm dup && pnpm build && pnpm size",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@storybook/react-vite": "^10.2.15",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-query": "latest",
    "@tanstack/react-query-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "lucide-react": "^0.545.0",
    "nitro": "npm:nitro-nightly@latest",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "storybook": "^10.2.15",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@size-limit/file": "^12.1.0",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/eslint-config": "latest",
    "@tanstack/router-cli": "^1.132.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.5.0",
    "husky": "^9.1.7",
    "jscpd": "^5.0.10",
    "jsdom": "^28.1.0",
    "knip": "^6.17.1",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.1",
    "size-limit": "^12.1.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  },
  "knip": {
    "ignoreDependencies": [
      "@tailwindcss/typography",
      "@testing-library/dom",
      "@testing-library/react",
      "lint-staged",
      "lucide-react"
    ]
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json,md,yaml,yml}": "prettier --write"
  }
}
