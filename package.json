{
  "name": "frontend",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.14.0",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --host 127.0.0.1 --port 3000",
    "generate-routes": "tsr generate",
    "build": "vite build && serwist build",
    "preview": "vite preview",
    "test": "vitest run",
    "start": "node .output/server/index.mjs",
    "prepare": "husky",
    "lint": "eslint",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "unused": "knip",
    "dup": "jscpd src --config .jscpd.json",
    "size": "size-limit",
    "lighthouse:ci": "lhci autorun --config=.lighthouserc.json",
    "check": "pnpm lint && pnpm typecheck && pnpm format:check && pnpm test && pnpm unused && pnpm dup && pnpm build && pnpm size",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@storybook/react-vite": "^10.2.15",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-query": "latest",
    "@tanstack/react-query-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "axios": "^1.18.0",
    "clsx": "^2.1.1",
    "dexie": "^4.4.4",
    "lucide-react": "^0.545.0",
    "nitro": "npm:nitro-nightly@latest",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.80.0",
    "serwist": "^9.5.11",
    "storybook": "^10.2.15",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@serwist/cli": "^9.5.11",
    "@size-limit/file": "^12.1.0",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/eslint-config": "latest",
    "@tanstack/router-cli": "^1.132.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.5.0",
    "husky": "^9.1.7",
    "jscpd": "^5.0.10",
    "jsdom": "^28.1.0",
    "knip": "^6.17.1",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.1",
    "sass": "^1.89.2",
    "size-limit": "^12.1.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vite-plugin-svgr": "^5.2.0",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  },
  "knip": {
    "entry": [
      "serwist.config.js",
      "src/sw.ts"
    ],
    "ignore": [
      "src/domain/repositories/**",
      "src/modules/auth/**",
      "src/modules/reviews/**",
      "src/modules/subscription/**",
      "src/modules/offline/model/index.ts",
      "src/modules/profile/ui/index.ts",
      "src/shared/api/**",
      "src/shared/config/styles/**",
      "src/shared/ui/**",
      "vite.storybook.config.ts"
    ],
    "ignoreIssues": {
      "src/modules/books/model/book-filters.ts": [
        "types"
      ],
      "src/modules/offline/model/index.ts": [
        "exports"
      ],
      "src/shared/lib/db/api-mappers.ts": [
        "exports"
      ],
      "src/shared/lib/db/index.ts": [
        "types"
      ],
      "src/shared/lib/db/types.ts": [
        "types"
      ]
    },
    "ignoreExportsUsedInFile": true,
    "ignoreDependencies": [
      "@hookform/resolvers",
      "@testing-library/dom",
      "@testing-library/react",
      "clsx",
      "lint-staged",
      "lucide-react",
      "react-hook-form",
      "zod"
    ]
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss,json,md,yaml,yml}": "prettier --write"
  }
}
