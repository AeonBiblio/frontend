<file path=".github/workflows/ci.yml">
name: quality

on:
  pull_request:
    branches: [main, dev]
    types: [opened, reopened, synchronize, ready_for_review]
  push:
    branches: [main, dev]

permissions:
  contents: read

concurrency:
  group: quality-${{ github.ref }}
  cancel-in-progress: true

jobs:
  quality:
    runs-on: ubuntu-latest
    timeout-minutes: 20

    steps:
      - name: Checkout
        uses: actions/checkout@v5

      - name: Setup pnpm
        uses: pnpm/action-setup@v4

      - name: Setup Node
        uses: actions/setup-node@v6
        with:
          node-version-file: .nvmrc
          cache: pnpm

      - name: Install
        run: pnpm install --frozen-lockfile

      - name: Lint
        run: pnpm lint

      - name: Typecheck
        run: pnpm typecheck

      - name: Format
        run: pnpm format:check

      - name: Test
        run: pnpm test

      - name: Build
        run: pnpm build

      - name: Unused code
        run: pnpm unused

      - name: Duplicate code
        run: pnpm dup

      - name: Bundle size
        run: pnpm size
</file>

