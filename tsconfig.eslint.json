{
  "extends": "./tsconfig.json",
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/sw.ts",
    "src/**/*.d.ts",
    "vite.config.ts",
    "vite.storybook.config.ts",
    "vitest.config.ts",
    "vitest.shims.d.ts",
    ".storybook/**/*.ts",
    "eslint.config.js",
    "prettier.config.js"
  ],
  "exclude": ["node_modules", ".output"],
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"]
  }
}
